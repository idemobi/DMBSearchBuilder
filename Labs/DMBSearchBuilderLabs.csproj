<Project Sdk="Microsoft.NET.Sdk.Razor">
    <PropertyGroup>
        <RootNamespace>DMBSearchBuilderLabs</RootNamespace>
        <AssemblyName>DMBSearchBuilderLabs</AssemblyName>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <IsPackable>false</IsPackable>
        <EnableDefaultRazorGenerateItems>true</EnableDefaultRazorGenerateItems>
        <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
        <IncludeRazorContentInPack>false</IncludeRazorContentInPack>
        <EmbedRazorGenerateSources>false</EmbedRazorGenerateSources>
    </PropertyGroup>

    <ItemGroup>
        <FrameworkReference Include="Microsoft.AspNetCore.App" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Source\Builder\DMBSearchBuilder.csproj" />
        <ProjectReference Include="..\Source\Core\DMBSearchCore.csproj" />
        <ProjectReference Include="..\Source\Viewer\DMBSearchViewer.csproj" />
    </ItemGroup>

    <Choose>
        <When Condition=" '$(Configuration)' == 'Release' ">
            <ItemGroup Label="Case Release">
                <PackageReference Include="DMBBootstrapBuilder" Version="0.26.0" />
                <PackageReference Include="DMBComponentBuilder" Version="0.26.0" />
                <PackageReference Include="DMBEffectBuilder" Version="0.26.0" />
                <PackageReference Include="DMBPageBuilder" Version="0.26.0" />
            </ItemGroup>
        </When>
        <Otherwise>
            <ItemGroup Label="Case Debug">
                <ProjectReference Include="..\..\DMBBootstrapBuilder\Source\DMBBootstrapBuilder.csproj" />
                <ProjectReference Include="..\..\DMBComponentBuilder\Source\DMBComponentBuilder.csproj" />
                <ProjectReference Include="..\..\DMBEffectBuilder\Source\DMBEffectBuilder.csproj" />
                <ProjectReference Include="..\..\DMBPageBuilder\Source\DMBPageBuilder.csproj" />
            </ItemGroup>
        </Otherwise>
    </Choose>
</Project>
