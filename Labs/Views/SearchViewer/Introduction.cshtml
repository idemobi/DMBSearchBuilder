@{
    Layout = "_Layout";
}

@* ── Hero ── *@
@using (Html.SectionBuilder().SetHeight(125, UnitSize.px).BootstrapBackgroundEffect(VariantStyle.Normal).Begin())
{
    @using (Html.FlexBlockBuilder().SetAlignItemsCenter().SetJustifyContentCenter().Begin())
    {
        @using (Html.BlockBuilder().AsTextCenter().Begin())
        {
            @Html.TitleBuilder().SetTitle("Introduction — SearchViewer", TitleLevel.One).Render()
            @using (Html.PB_P().AsLead().Begin())
            {
                @:Expose unified search from multiple providers.
            }
            @using (Html.FlexBlockBuilder().SetJustifyContentCenter().WithGap(Old_Gap.Gap2).Begin())
            {
                @Html.Button(ActionItemFactory.AspRoute("SearchViewer", "GettingStarted").SetTitle("Get Started").SetIcon(IconStruct.Bootstrap("bi-play-fill")).SetVariant(VariantStyle.Primary)).Render()
                @Html.Button(ActionItemFactory.AspRoute("SearchViewer", "Architecture").SetTitle("Architecture").SetIcon(IconStruct.Bootstrap("bi-diagram-3")).SetVariant(VariantStyle.Secondary).SetOutlined()).Render()
            }
        }
    }
}

@* ── 3 highlight cards ── *@
@using (Html.BlockBuilder().AsSectionContentTop().Begin())
{
    @using (Html.RowBuilder().AsPillarGrid().Begin())
    {
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsSidebarCard().Begin())
            {
                @using (Html.BlockBuilder().AsPaddedBlock().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-menu-button-wide fs-2 text-primary d-block mb-2").Begin()) { }
                    @using (Html.PB_Span().AsSemiBold().Begin())
                    {
                        @:Navbar Component
                    }
                    @using (Html.PB_P().AsSmallMuted().AsNoMargin().Begin())
                    {
                        @:Adds a compact search input to the profile side of the BootstrapBuilder navbar.
                    }
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsSidebarCard().Begin())
            {
                @using (Html.BlockBuilder().AsPaddedBlock().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-diagram-2 fs-2 text-success d-block mb-2").Begin()) { }
                    @using (Html.PB_Span().AsSemiBold().Begin())
                    {
                        @:Provider Contract
                    }
                    @using (Html.PB_P().AsSmallMuted().AsNoMargin().Begin())
                    {
                        @:Each source computes its own relevance and returns normalized results.
                    }
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsSidebarCard().Begin())
            {
                @using (Html.BlockBuilder().AsPaddedBlock().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-list-stars fs-2 text-warning d-block mb-2").Begin()) { }
                    @using (Html.PB_Span().AsSemiBold().Begin())
                    {
                        @:Merged Results Page
                    }
                    @using (Html.PB_P().AsSmallMuted().AsNoMargin().Begin())
                    {
                        @:Displays merged results with score, title, excerpt and navigable URL.
                    }
                }
            }
        }
    }
}

@* ── What is + preview ── *@
@using (Html.BlockBuilder().AsSectionContent().Begin())
{
    @using (Html.RowBuilder().SetGapY(Gap.G5).SetAlignItems(AlignItems.Center).Begin())
    {
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col7, ResponsiveBreakpoint.Lg).Begin())
        {
            @Html.TitleBuilder().SetTitle("What is SearchViewer?", TitleLevel.Two).AsSectionHeading().Render()
            @using (Html.PB_P().Begin())
            {
                @using (Html.PB_Span().AsBold().Begin())
                {
                    @:DMBSearchViewer
                }
                @: is the runtime module that injects a search component into the navbar and renders a result listing page. It does not own one specific database: it queries registered providers and merges their results through a common score contract.
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin())
                {
                    @:The first providers target
                    @using (Html.PB_Span().AsMonospace().Begin())
                    {
                        @:SearchBuilder
                    }
                    @: and
                    @using (Html.PB_Span().AsMonospace().Begin())
                    {
                        @:DocumentationViewer
                    }
                    @: databases
                }
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin())
                {
                    @:Future modules can add providers without changing the result page or navbar integration
                }
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin())
                {
                    @:Provider errors are isolated — one failing source does not block others
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col5, ResponsiveBreakpoint.Lg).Begin())
        {
            @using (Html.BlockBuilder().AsSidebarCard().Begin())
            {
                @using (Html.BlockBuilder().AsPaddedBlock().Begin())
                {
                    @(Html.CodeBlock(@"DMBSearchViewerConfiguration.LoadCommonConfig(builder);
DMBSearchViewerConfiguration.UseApp(app);", CodeLanguage.CSharp)
                        .SetCopyButton())
                    @using (Html.PB_P().AsSmallMuted().AsNoMargin().Begin())
                    {
                        @:Register SearchViewer in the website and let providers do the searching.
                    }
                }
            }
        }
    }
}

@* ── Three Pillars ── *@
@using (Html.BlockBuilder().AsSectionContent().Begin())
{
    @using (Html.BlockBuilder().AsTextCenter().Begin())
    {
        @Html.TitleBuilder().SetTitle("Three Pillars of SearchViewer", TitleLevel.Two).AsSectionHeading().Render()
        @using (Html.PB_P().AsMuted().Begin())
        {
            @:Each pillar handles a distinct responsibility in the runtime search experience.
        }
    }
    @using (Html.RowBuilder().AsPillarGrid().Begin())
    {
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsPillarCard().Begin())
            {
                @using (Html.BlockBuilder().AsTopMargin().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-menu-button-wide text-primary me-1").Begin()) { }
                    @Html.TitleBuilder().SetTitle("Navbar Component", TitleLevel.Five).AsCompact().Render()
                }
                @using (Html.PB_P().AsSmallMuted().Begin())
                {
                    @:Adds a compact search input to the profile side of the BootstrapBuilder navbar.
                }
                @using (Html.PB_Span().AsMonospaceSmall().Begin())
                {
                    @:DMBSearchNavbarComponent
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsPillarCard().Begin())
            {
                @using (Html.BlockBuilder().AsTopMargin().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-diagram-2 text-success me-1").Begin()) { }
                    @Html.TitleBuilder().SetTitle("Provider Contract", TitleLevel.Five).AsCompact().Render()
                }
                @using (Html.PB_P().AsSmallMuted().Begin())
                {
                    @:Lets each source compute its own relevance and return a normalized result.
                }
                @using (Html.PB_Span().AsMonospaceSmall().Begin())
                {
                    @:IDMBSearchProvider
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsPillarCard().Begin())
            {
                @using (Html.BlockBuilder().AsTopMargin().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-list-stars text-warning me-1").Begin()) { }
                    @Html.TitleBuilder().SetTitle("Results Page", TitleLevel.Five).AsCompact().Render()
                }
                @using (Html.PB_P().AsSmallMuted().Begin())
                {
                    @:Displays merged results with score, title, excerpt and navigable URL.
                }
                @using (Html.PB_Span().AsMonospaceSmall().Begin())
                {
                    @:/Search
                }
            }
        }
    }
}

@* ── Philosophy ── *@
@using (Html.BlockBuilder().AsSectionContent().Begin())
{
    @using (Html.FlexBlockBuilder().WithGap(Old_Gap.Gap3).SetAlignItemsStretch().Begin())
    {
        @using (Html.BlockBuilder().AsInfoCallout().SetStyle("margin", "0").SetStyle("flex", "2").Begin())
        {
            @using (Html.FlexBlockBuilder().Begin())
            {
                @using (Html.BlockBuilder().AsCalloutIcon().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-lightbulb-fill fs-2 text-info").Begin()) { }
                }
                @using (Html.BlockBuilder().Begin())
                {
                    @Html.TitleBuilder().SetTitle("Core Philosophy", TitleLevel.Four).AsAlertHeading().Render()
                    @using (Html.PB_P().AsNoMargin().Begin())
                    {
                        @:SearchViewer should be source-agnostic. Providers know how to search their data. The viewer knows how to collect, sort and present
                        @using (Html.PB_Span().AsItalic().Begin())
                        {
                            @:normalized results
                        }
                        @: — regardless of how each source computed relevance.
                    }
                }
            }
        }
        @using (Html.BlockBuilder().AsSidebarCard().SetStyle("flex", "1").Begin())
        {
            @using (Html.BlockBuilder().AsPaddedBlock().SetStyle("height", "100%").Begin())
            {
                @using (Html.FlexBlockBuilder().SetFlexColumn().SetAlignItemsStart().SetJustifyContentCenter().SetStyle("height", "100%").Begin())
                {
                    @Html.TitleBuilder().SetTitle("Next Step", TitleLevel.Five).Render()
                    @using (Html.PB_P().AsSmallMuted().Begin())
                    {
                        @:Configure the viewer and available providers.
                    }
                    @Html.Button(ActionItemFactory.AspRoute("SearchViewer", "GettingStarted").SetTitle("Getting Started").SetIcon(IconStruct.Bootstrap("bi-play-fill")).SetVariant(VariantStyle.Primary)).Render()
                }
            }
        }
    }
}
