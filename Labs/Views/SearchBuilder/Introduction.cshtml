@{
    Layout = "_Layout";
}

@* ── Hero ── *@
@using (Html.SectionBuilder().SetHeight(125, UnitSize.px).BootstrapBackgroundEffect(VariantStyle.Normal).Begin())
{
    @using (Html.FlexBlockBuilder().SetAlignItemsCenter().SetJustifyContentCenter().Begin())
    {
        @using (Html.BlockBuilder().AsTextCenter().Begin())
        {
            @Html.TitleBuilder().SetTitle("Introduction — SearchBuilder", TitleLevel.One).Render()
            @using (Html.PB_P().AsLead().Begin())
            {
                @:Generate a local search index from a running website.
            }
            @using (Html.FlexBlockBuilder().SetJustifyContentCenter().WithGap(Old_Gap.Gap2).Begin())
            {
                @Html.Button(ActionItemFactory.AspRoute("SearchBuilder", "GettingStarted").SetTitle("Get Started").SetIcon(IconStruct.Bootstrap("bi-play-fill")).SetVariant(VariantStyle.Primary)).Render()
                @Html.Button(ActionItemFactory.AspRoute("SearchBuilder", "Architecture").SetTitle("Architecture").SetIcon(IconStruct.Bootstrap("bi-diagram-3")).SetVariant(VariantStyle.Secondary).SetOutlined()).Render()
            }
        }
    }
}

@* ── 3 highlight cards ── *@
@using (Html.BlockBuilder().AsSectionContentTop().Begin())
{
    @using (Html.RowBuilder().AsPillarGrid().Begin())
    {
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsSidebarCard().Begin())
            {
                @using (Html.BlockBuilder().AsPaddedBlock().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-signpost-split fs-2 text-primary d-block mb-2").Begin()) { }
                    @using (Html.PB_Span().AsSemiBold().Begin())
                    {
                        @:Prebuild Crawling
                    }
                    @using (Html.PB_P().AsSmallMuted().AsNoMargin().Begin())
                    {
                        @:Walks same-site links before runtime — production never crawls itself.
                    }
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsSidebarCard().Begin())
            {
                @using (Html.BlockBuilder().AsPaddedBlock().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-sliders fs-2 text-success d-block mb-2").Begin()) { }
                    @using (Html.PB_Span().AsSemiBold().Begin())
                    {
                        @:Weighted Terms
                    }
                    @using (Html.PB_P().AsSmallMuted().AsNoMargin().Begin())
                    {
                        @:Title, headings, description and body each carry their own relevance weight.
                    }
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsSidebarCard().Begin())
            {
                @using (Html.BlockBuilder().AsPaddedBlock().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-database fs-2 text-warning d-block mb-2").Begin()) { }
                    @using (Html.PB_Span().AsSemiBold().Begin())
                    {
                        @:Portable SQLite
                    }
                    @using (Html.PB_P().AsSmallMuted().AsNoMargin().Begin())
                    {
                        @:Outputs a single database file deployable alongside the host website.
                    }
                }
            }
        }
    }
}

@* ── What is + preview ── *@
@using (Html.BlockBuilder().AsSectionContent().Begin())
{
    @using (Html.RowBuilder().SetGapY(Gap.G5).SetAlignItems(AlignItems.Center).Begin())
    {
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col7, ResponsiveBreakpoint.Lg).Begin())
        {
            @Html.TitleBuilder().SetTitle("What is SearchBuilder?", TitleLevel.Two).AsSectionHeading().Render()
            @using (Html.PB_P().Begin())
            {
                @using (Html.PB_Span().AsBold().Begin())
                {
                    @:DMBSearchBuilder
                }
                @: is the build-time module that crawls a website and writes a SQLite search database. It extracts page titles, descriptions, visible text and weighted terms so
                @using (Html.PB_Span().AsMonospace().Begin())
                {
                    @:DMBSearchViewer
                }
                @: can return relevant results at runtime.
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin())
                {
                    @:Designed for prebuilding — production consumes the generated database without crawling itself
                }
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin())
                {
                    @:Can run against a local launch profile to keep crawling separate from production
                }
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin())
                {
                    @:PascalCase-aware normalizer indexes both
                    @using (Html.PB_Span().AsMonospace().Begin())
                    {
                        @:TitleBuilder
                    }
                    @: and
                    @using (Html.PB_Span().AsMonospace().Begin())
                    {
                        @:title builder
                    }
                    @: automatically
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col5, ResponsiveBreakpoint.Lg).Begin())
        {
            @using (Html.BlockBuilder().AsSidebarCard().Begin())
            {
                @using (Html.BlockBuilder().AsPaddedBlock().Begin())
                {
                    @(Html.CodeBlock(@"await new SearchBuilderAgent()
    .BuildFromLaunchProfileAsync(options);", CodeLanguage.CSharp)
                        .SetCopyButton())
                    @using (Html.PB_P().AsSmallMuted().AsNoMargin().Begin())
                    {
                        @:Run the crawler from a prebuilding project against a local launch profile.
                    }
                }
            }
        }
    }
}

@* ── Three Pillars ── *@
@using (Html.BlockBuilder().AsSectionContent().Begin())
{
    @using (Html.BlockBuilder().AsTextCenter().Begin())
    {
        @Html.TitleBuilder().SetTitle("Three Pillars of SearchBuilder", TitleLevel.Two).AsSectionHeading().Render()
        @using (Html.PB_P().AsMuted().Begin())
        {
            @:Each pillar handles a distinct responsibility in the build pipeline.
        }
    }
    @using (Html.RowBuilder().AsPillarGrid().Begin())
    {
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsPillarCard().Begin())
            {
                @using (Html.BlockBuilder().AsTopMargin().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-signpost-split text-primary me-1").Begin()) { }
                    @Html.TitleBuilder().SetTitle("Site Crawl", TitleLevel.Five).AsCompact().Render()
                }
                @using (Html.PB_P().AsSmallMuted().Begin())
                {
                    @:Walks same-site links from the configured base URL while excluding paths such as documentation and search pages.
                }
                @using (Html.PB_Span().AsMonospaceSmall().Begin())
                {
                    @:SearchBuilderAgent
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsPillarCard().Begin())
            {
                @using (Html.BlockBuilder().AsTopMargin().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-sliders text-success me-1").Begin()) { }
                    @Html.TitleBuilder().SetTitle("Weighted Terms", TitleLevel.Five).AsCompact().Render()
                }
                @using (Html.PB_P().AsSmallMuted().Begin())
                {
                    @:Stores normalized terms with relevance weights from title, headings, description, URL and body content.
                }
                @using (Html.PB_Span().AsMonospaceSmall().Begin())
                {
                    @:SearchPageTerms
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsPillarCard().Begin())
            {
                @using (Html.BlockBuilder().AsTopMargin().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-database text-warning me-1").Begin()) { }
                    @Html.TitleBuilder().SetTitle("SQLite Output", TitleLevel.Five).AsCompact().Render()
                }
                @using (Html.PB_P().AsSmallMuted().Begin())
                {
                    @:Writes a portable database file that can be deployed with the host website.
                }
                @using (Html.PB_Span().AsMonospaceSmall().Begin())
                {
                    @:Search/data.db
                }
            }
        }
    }
}

@* ── Philosophy ── *@
@using (Html.BlockBuilder().AsSectionContent().Begin())
{
    @using (Html.FlexBlockBuilder().WithGap(Old_Gap.Gap3).SetAlignItemsStretch().Begin())
    {
        @using (Html.BlockBuilder().AsInfoCallout().SetStyle("margin", "0").SetStyle("flex", "2").Begin())
        {
            @using (Html.FlexBlockBuilder().Begin())
            {
                @using (Html.BlockBuilder().AsCalloutIcon().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-lightbulb-fill fs-2 text-info").Begin()) { }
                }
                @using (Html.BlockBuilder().Begin())
                {
                    @Html.TitleBuilder().SetTitle("Core Philosophy", TitleLevel.Four).AsAlertHeading().Render()
                    @using (Html.PB_P().AsNoMargin().Begin())
                    {
                        @:SearchBuilder should do expensive discovery before runtime.
                        @using (Html.PB_Span().AsMonospace().Begin())
                        {
                            @:SearchViewer
                        }
                        @: should only query prepared data. That separation keeps the website responsive and avoids crawling production pages.
                    }
                }
            }
        }
        @using (Html.BlockBuilder().AsSidebarCard().SetStyle("flex", "1").Begin())
        {
            @using (Html.BlockBuilder().AsPaddedBlock().SetStyle("height", "100%").Begin())
            {
                @using (Html.FlexBlockBuilder().SetFlexColumn().SetAlignItemsStart().SetJustifyContentCenter().SetStyle("height", "100%").Begin())
                {
                    @Html.TitleBuilder().SetTitle("Next Step", TitleLevel.Five).Render()
                    @using (Html.PB_P().AsSmallMuted().Begin())
                    {
                        @:Configure a launch profile and database path in the prebuilding project.
                    }
                    @Html.Button(ActionItemFactory.AspRoute("SearchBuilder", "GettingStarted").SetTitle("Getting Started").SetIcon(IconStruct.Bootstrap("bi-play-fill")).SetVariant(VariantStyle.Primary)).Render()
                }
            }
        }
    }
}
